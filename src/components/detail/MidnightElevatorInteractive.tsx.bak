import { useEffect, useRef, useState, useCallback } from 'react'
import { motion } from 'framer-motion'

type Phase = 'closed' | 'intro' | 'choice' | 'loading-branch' | 'branch-a' | 'branch-b' | 'ending'

// Timing constants from video analysis
const CHOICE_TRIGGER_TIME = 20.1  // pause just BEFORE choice UI appears (~20.4s)

interface Props { open: boolean; onClose: () => void }

export default function MidnightElevatorInteractive({ open, onClose }: Props) {
  const [phase, setPhase] = useState<Phase>('closed')
  const [chosenBranch, setChosenBranch] = useState<'a' | 'b' | null>(null)

  const introRef = useRef<HTMLVideoElement>(null!)
  const branchARef = useRef<HTMLVideoElement>(null!)
  const branchBRef = useRef<HTMLVideoElement>(null!)
  const scrollY = useRef(0)
  const choiceTimerFired = useRef(false)

  // Lock / unlock body
  useEffect(() => {
    if (open) {
      scrollY.current = window.scrollY
      document.body.style.overflow = 'hidden'; document.body.style.position = 'fixed'
      document.body.style.top = `-${scrollY.current}px`; document.body.style.width = '100%'
      setPhase('intro'); choiceTimerFired.current = false
    }
    return () => {
      document.body.style.overflow = ''; document.body.style.position = ''
      document.body.style.top = ''; document.body.style.width = ''
    }
  }, [open])

  // Play intro when phase becomes 'intro'
  useEffect(() => {
    if (phase === 'intro' && introRef.current) {
      introRef.current.currentTime = 0
      introRef.current.play().catch(() => {})
    }
  }, [phase])

  // Timeupdate listener — pause at choice trigger time
  const handleIntroTimeUpdate = useCallback(() => {
    if (choiceTimerFired.current) return
    const v = introRef.current
    if (v && v.currentTime >= CHOICE_TRIGGER_TIME) {
      choiceTimerFired.current = true
      v.pause()
      setPhase('choice')
    }
  }, [])

  // Fallback: if timeupdate doesn't fire (e.g. seeking), also check on ended
  const handleIntroEnded = () => {
    if (!choiceTimerFired.current) {
      choiceTimerFired.current = true
      setPhase('choice')
    }
  }

  // Choose branch
  const chooseBranch = useCallback((branch: 'a' | 'b') => {
    setChosenBranch(branch)
    setPhase('loading-branch')

    // Preload the branch video
    const ref = branch === 'a' ? branchARef : branchBRef
    const newPhase = branch === 'a' ? 'branch-a' : 'branch-b'

    if (ref.current) {
      ref.current.currentTime = 0
      ref.current.load()

      const onCanPlay = () => {
        ref.current?.removeEventListener('canplay', onCanPlay)
        // Crossfade: branch starts playing, intro kept as backdrop briefly
        ref.current?.play().catch(() => {})
        setPhase(newPhase)
        // Unload intro after transition
        setTimeout(() => {
          if (introRef.current) { introRef.current.pause(); introRef.current.currentTime = 0 }
        }, 300)
      }
      ref.current.addEventListener('canplay', onCanPlay)

      // Timeout fallback
      setTimeout(() => {
        if (ref.current && ref.current.readyState >= 2 && phase === 'loading-branch') {
          ref.current.play().catch(() => {})
          setPhase(newPhase)
        }
      }, 2000)
    }
  }, [phase])

  // Branch ended
  const handleBranchEnded = () => setPhase('ending')

  // View other ending — directly load the alternate branch
  const viewOther = () => {
    const target = chosenBranch === 'a' ? 'b' : 'a'
    // Stop current branch
    const oldRef = chosenBranch === 'a' ? branchARef : branchBRef
    if (oldRef.current) { oldRef.current.pause(); oldRef.current.currentTime = 0 }
    setChosenBranch(target)
    setPhase('loading-branch')

    const newRef = target === 'a' ? branchARef : branchBRef
    if (newRef.current) {
      newRef.current.currentTime = 0
      newRef.current.load()
      const onCanPlay = () => {
        newRef.current?.removeEventListener('canplay', onCanPlay)
        newRef.current?.play().catch(() => {})
        setPhase(target === 'a' ? 'branch-a' : 'branch-b')
      }
      newRef.current.addEventListener('canplay', onCanPlay)
    }
  }

  // Restart — back to intro 0s
  const restart = () => {
    [branchARef, branchBRef].forEach(r => { if (r.current) { r.current.pause(); r.current.currentTime = 0 } })
    setChosenBranch(null)
    choiceTimerFired.current = false
    setPhase('intro')
  }

  // Close
  const handleClose = useCallback(() => {
    [introRef, branchARef, branchBRef].forEach(r => {
      if (r.current) { r.current.pause(); r.current.currentTime = 0 }
    })
    setPhase('closed')
    document.body.style.overflow = ''; document.body.style.position = ''
    document.body.style.top = ''; document.body.style.width = ''
    window.scrollTo({ top: scrollY.current, behavior: 'instant' as ScrollBehavior })
    onClose()
  }, [onClose])

  // Keyboard
  useEffect(() => {
    if (!open) return
    const onKey = (e: KeyboardEvent) => {
      if (e.key === 'Escape') { handleClose(); return }
      if (phase === 'choice') {
        if (e.key === 'a' || e.key === 'A') chooseBranch('a')
        if (e.key === 'b' || e.key === 'B') chooseBranch('b')
      }
    }
    window.addEventListener('keydown', onKey); return () => window.removeEventListener('keydown', onKey)
  }, [open, phase, handleClose, chooseBranch])

  if (!open) return null

  return (
    <div className="fixed inset-0 z-[120] flex flex-col items-center justify-center bg-black/92 backdrop-blur-md">
      {/* Close button */}
      <button onClick={handleClose}
        className="absolute top-4 right-4 z-20 rounded-full bg-white/10 p-2.5 text-white/60 hover:text-white transition-colors" aria-label="关闭">
        <svg className="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="1.5"><path strokeLinecap="round" strokeLinejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>

      {/* Video container — 9:16, centered */}
      <div className="relative" style={{ height: 'min(85vh, 95vw * 16/9)' }}>
        {/* Intro — always visible until choice is made as backdrop */}
        {(phase === 'intro' || phase === 'choice') && (
          <video ref={introRef} src="/projects/midnight-elevator/interactive/intro.mp4"
            className="h-full w-auto max-w-[90vw] object-contain rounded-lg"
            playsInline preload="metadata"
            onTimeUpdate={handleIntroTimeUpdate}
            onEnded={handleIntroEnded} />
        )}

        {/* Branch A */}
        {(phase === 'loading-branch' || phase === 'branch-a' || (phase === 'ending' && chosenBranch === 'a')) && (
          <video ref={branchARef} src="/projects/midnight-elevator/interactive/branch-a.mp4"
            className="h-full w-auto max-w-[90vw] object-contain rounded-lg"
            playsInline preload="metadata" onEnded={handleBranchEnded} />
        )}

        {/* Branch B */}
        {(phase === 'loading-branch' || phase === 'branch-b' || (phase === 'ending' && chosenBranch === 'b')) && (
          <video ref={branchBRef} src="/projects/midnight-elevator/interactive/branch-b.mp4"
            className="h-full w-auto max-w-[90vw] object-contain rounded-lg"
            playsInline preload="metadata" onEnded={handleBranchEnded} />
        )}

        {/* Choice overlay — ON TOP of paused intro frame */}
        {phase === 'choice' && (
          <motion.div className="absolute inset-0 flex flex-col items-center justify-end pb-24 rounded-lg"
            style={{ background: 'radial-gradient(ellipse at center, transparent 50%, rgba(0,0,0,0.15) 100%)' }}
            initial={{ opacity: 0 }} animate={{ opacity: 1 }} transition={{ duration: 0.3 }}>
            {/* Transparent click zones over video's built-in choice UI */}
            <div className="absolute inset-0 flex">
              <button onClick={() => chooseBranch('a')}
                className="flex-1 h-full cursor-pointer" aria-label="打开门"
                style={{ background: 'transparent' }} />
              <button onClick={() => chooseBranch('b')}
                className="flex-1 h-full cursor-pointer" aria-label="按住关门键"
                style={{ background: 'transparent' }} />
            </div>
            {/* Subtle text hints below video area */}
            <div className="relative flex gap-12 mt-4">
              <span className="text-[14px] font-semibold" style={{ color: 'rgba(220,80,60,0.8)' }}>A 打开门</span>
              <span className="text-[14px] font-semibold" style={{ color: 'rgba(180,200,220,0.7)' }}>B 按住关门键</span>
            </div>
          </motion.div>
        )}
      </div>

      {/* Loading indicator */}
      {phase === 'loading-branch' && (
        <div className="mt-4 flex items-center gap-2">
          <div className="w-3 h-3 rounded-full animate-pulse" style={{ backgroundColor: 'rgba(200,192,184,0.3)' }} />
          <p className="text-[11px] tracking-[0.1em] uppercase" style={{ color: 'rgba(200,192,184,0.25)' }}>LOADING BRANCH</p>
        </div>
      )}

      {/* Ending UI */}
      {phase === 'ending' && (
        <motion.div className="mt-6 flex gap-4 flex-wrap justify-center"
          initial={{ opacity: 0, y: 12 }} animate={{ opacity: 1, y: 0 }} transition={{ duration: 0.4 }}>
          <button onClick={viewOther}
            className="rounded-full border px-5 py-2.5 text-[13px] font-medium transition-all duration-300 min-w-[44px] min-h-[44px] hover:scale-105"
            style={{ borderColor: 'rgba(200,192,184,0.12)', color: 'rgba(200,192,184,0.5)' }}>
            查看另一结局
          </button>
          <button onClick={restart}
            className="rounded-full border px-5 py-2.5 text-[13px] font-medium transition-all duration-300 min-w-[44px] min-h-[44px]"
            style={{ borderColor: 'rgba(200,192,184,0.08)', color: 'rgba(200,192,184,0.35)' }}>
            重新开始
          </button>
          <button onClick={handleClose}
            className="rounded-full border px-5 py-2.5 text-[13px] font-medium transition-all duration-300 min-w-[44px] min-h-[44px]"
            style={{ borderColor: 'rgba(200,192,184,0.06)', color: 'rgba(200,192,184,0.25)' }}>
            返回详情页
          </button>
        </motion.div>
      )}
    </div>
  )
}
